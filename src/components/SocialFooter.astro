---
import Default from '@astrojs/starlight/components/Footer.astro';
---

<Default><slot /></Default>

<footer class="pe-social-footer">
  <div class="pe-social-links">
    <a href="https://mussaab.com" target="_blank" rel="noopener" title="Website">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/></svg>
      mussaab.com
    </a>
    <a href="https://vimeo.com/mussaab" target="_blank" rel="noopener" title="Vimeo">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.977 6.416c-.105 2.338-1.739 5.543-4.894 9.609-3.268 4.247-6.026 6.37-8.29 6.37-1.409 0-2.578-1.294-3.553-3.881L5.322 11.4C4.603 8.816 3.834 7.522 3.01 7.522c-.179 0-.806.378-1.881 1.132L0 7.197a315.065 315.065 0 0 0 3.564-3.168C5.06 2.725 6.193 1.99 6.981 1.938c1.883-.18 3.045 1.1 3.479 3.832.469 2.9.792 4.704.969 5.405.537 2.405 1.131 3.603 1.778 3.603.5 0 1.256-.796 2.265-2.385 1.015-1.589 1.556-2.797 1.635-3.627.146-1.365-.395-2.05-1.635-2.05-.582 0-1.179.13-1.794.396 1.19-3.898 3.466-5.8 6.816-5.696 2.479.075 3.654 1.688 3.479 4.8z"/></svg>
      Vimeo
    </a>
    <a href="https://medium.com/@mussaab.com" target="_blank" rel="noopener" title="Medium">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M13.54 12a6.8 6.8 0 01-6.77 6.82A6.8 6.8 0 010 12a6.8 6.8 0 016.77-6.82A6.8 6.8 0 0113.54 12zM20.96 12c0 3.54-1.51 6.42-3.38 6.42-1.87 0-3.39-2.88-3.39-6.42s1.52-6.42 3.39-6.42 3.38 2.88 3.38 6.42M24 12c0 3.17-.53 5.75-1.19 5.75-.66 0-1.19-2.58-1.19-5.75s.53-5.75 1.19-5.75C23.47 6.25 24 8.83 24 12z"/></svg>
      Medium
    </a>
  </div>
  <p class="pe-copyright">© {new Date().getFullYear()} Mossaab Mohamed Ali · <a href="https://mussaab.com" target="_blank" rel="noopener">mussaab.com</a></p>
</footer>

<style>
  .pe-social-footer {
    border-top: 1px solid var(--sl-color-hairline);
    padding: 1.5rem var(--sl-content-pad-x);
    text-align: center;
    margin-top: 1rem;
  }
  .pe-social-links {
    display: flex;
    justify-content: center;
    flex-wrap: wrap;
    gap: 1.25rem;
    margin-bottom: 0.75rem;
  }
  .pe-social-links a {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    color: var(--sl-color-text-accent);
    text-decoration: none;
    font-size: 0.875rem;
  }
  .pe-social-links a:hover { color: var(--sl-color-accent); }
  .pe-copyright {
    font-size: 0.8rem;
    color: var(--sl-color-gray-3);
    margin: 0;
  }
  .pe-copyright a { color: var(--sl-color-text-accent); text-decoration: none; }
</style>
