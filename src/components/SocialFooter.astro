---
import Default from '@astrojs/starlight/components/PageSidebar.astro';
---

<Default><slot /></Default>

<div class="pe-sidebar-footer">
  <a href="https://ko-fi.com/mussaab" target="_blank" rel="noopener" class="pe-kofi">
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M23.881 8.948c-.773-4.085-4.859-4.593-4.859-4.593H.723c-.604 0-.679.798-.679.798s-.082 7.324-.022 11.822c.164 2.424 2.586 2.672 2.586 2.672s8.267-.023 11.966-.049c2.438-.426 2.683-2.566 2.658-3.734 4.352.24 7.422-2.831 6.649-6.916zm-11.062 3.511c-1.246 1.453-4.011 3.976-4.011 3.976s-.121.119-.31.023c-.076-.057-.108-.09-.108-.09-.443-.441-3.368-3.049-4.034-3.954-.709-.965-1.041-2.7-.091-3.71.951-1.01 3.005-1.086 4.363.407 0 0 1.565-1.782 3.468-.963 1.904.82 1.832 3.011.723 4.311zm6.173.478c-.928.116-1.682.028-1.682.028V7.284h1.77s1.971.551 1.971 2.638c0 1.913-.985 2.667-2.059 3.015z"/></svg>
    Support on Ko-fi
  </a>
  <p class="pe-footer-credit">© {new Date().getFullYear()} <a href="https://mussaab.com" target="_blank" rel="noopener">Mossaab Mohamed Ali</a></p>
</div>

<style>
  .pe-sidebar-footer {
    position: sticky;
    bottom: 0;
    padding: 1rem 0 1.5rem;
    border-top: 1px solid var(--sl-color-hairline);
    text-align: center;
    background-color: var(--sl-color-bg-sidebar);
  }
  .pe-kofi {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.35rem 0.75rem;
    margin-bottom: 0.6rem;
    border-radius: 6px;
    background: #ff5e5b;
    color: #fff !important;
    font-size: var(--sl-text-xs);
    font-weight: 600;
    text-decoration: none;
    transition: opacity 0.15s;
  }
  .pe-kofi:hover { opacity: 0.85; }
  .pe-footer-credit {
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    margin: 0;
  }
  .pe-footer-credit a { color: var(--sl-color-gray-2); text-decoration: none; }
  .pe-footer-credit a:hover { color: var(--sl-color-accent); }
</style>
