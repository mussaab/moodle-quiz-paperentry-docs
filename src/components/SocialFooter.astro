---
import Default from '@astrojs/starlight/components/PageSidebar.astro';
---

<Default><slot /></Default>

<div class="pe-sidebar-footer">
  <p>© {new Date().getFullYear()} <a href="https://mussaab.com" target="_blank" rel="noopener">Mossaab Mohamed Ali</a></p>
  <p>Built with <a href="https://starlight.astro.build" target="_blank" rel="noopener">Starlight</a></p>
</div>

<style>
  .pe-sidebar-footer {
    margin-top: auto;
    padding-top: 1.5rem;
    font-size: var(--sl-text-xs);
    color: var(--sl-color-gray-3);
    line-height: 1.8;
  }
  .pe-sidebar-footer p { margin: 0; }
  .pe-sidebar-footer a {
    color: var(--sl-color-gray-2);
    text-decoration: none;
  }
  .pe-sidebar-footer a:hover { color: var(--sl-color-accent); }
</style>
